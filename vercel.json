{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "functions": {
    "api/**/*.ts": {
      "runtime": "@vercel/node@5.3.13"
    }
  },
  "routes": [
    {
      "src": "/session/(.*)",
      "dest": "/api/session/$1"
    },
    {
      "src": "/auth/start",
      "dest": "/api/auth/start"
    },
    {
      "src": "/auth/callback",
      "dest": "/api/auth/callback"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    }
  ]
}
