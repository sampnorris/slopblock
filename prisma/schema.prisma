generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum SessionStatus {
  awaiting_answer
  passed
  skipped
  failed
  quota_exceeded
}

model InstallationSettings {
  id               String   @id @default(cuid())
  installationId   String   @unique
  accountLogin     String
  accountType      String   @default("User")
  marketplacePlan  String?
  marketplacePlanId Int?
  llmApiKeyEncrypted String?
  llmBaseUrl       String?
  llmGenerationModel String?
  llmValidationModel String?
  llmSkipModel     String?
  questionCountMin Int?
  questionCountMax Int?
  quizGenerationMaxAttempts Int?
  allowBestEffortFallback Boolean?
  retryMode        String?
  skipBots         Boolean?
  skipForks        Boolean?
  customSystemPrompt String?
  customQuizInstructions String?
  allowedWrongAnswers Int?
  maxTokenBudget   Int?
  tokenBudgetFallback String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model PullRequestSession {
  id                   String        @id @default(cuid())
  installationId       String
  repositoryId         String
  repositoryOwner      String
  repositoryName       String
  pullNumber           Int
  authorLogin          String
  headSha              String
  status               SessionStatus
  currentQuestionIndex Int           @default(0)
  questionCount        Int           @default(0)
  retryMode            String
  allowedWrongAnswers  Int           @default(0)
  generationModel      String?
  validationModel      String?
  summary              String?
  skipReason           String?
  failureMessage       String?
  commentId            String?
  quiz                 Json?
  traceId              String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@unique([repositoryOwner, repositoryName, pullNumber])
  @@index([installationId])
}

model QuizAttempt {
  id              String   @id @default(cuid())
  sessionId       String?
  installationId  String
  repositoryId    String
  repositoryOwner String
  repositoryName  String
  pullNumber      Int
  authorLogin     String
  headSha         String
  attemptNumber   Int
  retryMode       String
  generationModel String?
  validationModel String?
  questionCount   Int
  correctCount    Int
  passed          Boolean
  answers         Json?
  createdAt       DateTime @default(now())

  @@index([sessionId])
  @@index([installationId])
  @@index([repositoryOwner, repositoryName])
  @@index([authorLogin])
  @@index([passed])
  @@index([createdAt])
}
