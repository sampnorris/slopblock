generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum SessionStatus {
  awaiting_answer
  passed
  skipped
  failed
}

model InstallationSettings {
  id               String   @id @default(cuid())
  installationId   String   @unique
  accountLogin     String
  llmApiKey        String?
  llmBaseUrl       String?
  llmGenerationModel String?
  llmValidationModel String?
  llmSkipModel     String?
  questionCountMin Int?
  questionCountMax Int?
  retryMode        String?
  skipBots         Boolean?
  skipForks        Boolean?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model PullRequestSession {
  id                   String        @id @default(cuid())
  installationId       String
  repositoryId         String
  repositoryOwner      String
  repositoryName       String
  pullNumber           Int
  authorLogin          String
  headSha              String
  status               SessionStatus
  currentQuestionIndex Int           @default(0)
  questionCount        Int           @default(0)
  retryMode            String
  summary              String?
  skipReason           String?
  failureMessage       String?
  commentId            String?
  quiz                 Json?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@unique([repositoryOwner, repositoryName, pullNumber])
  @@index([installationId])
}
